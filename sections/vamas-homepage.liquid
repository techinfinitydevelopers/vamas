{% comment %} ── Testimonials ─────────────────────── {% endcomment %}
{% assign test_blocks = section.blocks | where: 'type', 'testimonial' %}
{% if test_blocks.size > 0 and section.settings.show_testimonials %}
<section class="vamas-section vamas-section--alt">
  <div class="vamas-section__header">
    <div>
      <h2 class="vamas-section__title">Customer <span>Reviews</span></h2>
      <p class="vamas-section__subtitle">Over 10,000 happy customers</p>
    </div>
  </div>
  <div class="vamas-test-grid">
    {% for block in section.blocks %}
      {% if block.type == 'testimonial' %}
        <div class="vamas-test-card">
          <div class="vamas-test-card__stars">
            {% for i in (1..block.settings.rating) %}★{% endfor %}
          </div>
          <p class="vamas-test-card__text">"{{ block.settings.review_text }}"</p>
          <div class="vamas-test-card__author">
            <div class="vamas-test-card__avatar">{{ block.settings.reviewer_name | slice: 0 | upcase }}</div>
            <div>
              <div class="vamas-test-card__name">{{ block.settings.reviewer_name }}</div>
              <div class="vamas-test-card__info">Verified Buyer · {{ block.settings.product_type | default: 'Blouse Collection' }}</div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% comment %} ── Newsletter ───────────────────────── {% endcomment %}
{% if section.settings.show_newsletter %}
<section class="vamas-newsletter">
  <p class="vamas-newsletter__eyebrow">EXCLUSIVE UPDATES</p>
  <h2 class="vamas-newsletter__heading">{{ section.settings.nl_heading | default: 'Stay in Style' }}</h2>
  <p class="vamas-newsletter__sub">{{ section.settings.nl_subtext | default: 'Subscribe for new arrivals, exclusive offers & style inspiration' }}</p>
  {% form 'customer', id: 'vamas-nl-form' %}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="vamas-newsletter__form">
      <input class="vamas-newsletter__input" type="email" name="contact[email]"
             placeholder="{{ section.settings.nl_placeholder | default: 'Your email address' }}" required>
      <button type="submit" class="vamas-newsletter__btn">
        {{ section.settings.nl_btn | default: 'SUBSCRIBE' }}
      </button>
    </div>
    {% if form.posted_successfully? %}
      <p style="color:var(--color-maroon);margin-top:16px;font-size:14px;font-weight:700;">
        Thank you for subscribing! ✦
      </p>
    {% endif %}
  {% endform %}
</section>
{% endif %}

