{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

{% comment %} ── Announcement Bar ─────────────────── {% endcomment %}
{% if section.settings.show_announce %}
<div class="vamas-announce">{{ section.settings.announce_text }}</div>
{% endif %}

{% comment %} ── Hero Slider ──────────────────────── {% endcomment %}
<div class="vamas-slider" id="vamas-slider">
  <div class="vamas-slider__track" id="vamas-track">

    {% for block in section.blocks %}
      {% if block.type == 'slide' %}
        <div class="vamas-slide" style="background: {{ block.settings.slide_bg | default: '#420001' }};">
          <div class="vamas-slide__text">
            <p class="vamas-slide__eyebrow">{{ block.settings.eyebrow }}</p>
            <h1 class="vamas-slide__heading">
              {{ block.settings.line1 }}<br>
              <em>{{ block.settings.line2_accent }}</em><br>
              {{ block.settings.line3 }}
            </h1>
            <p class="vamas-slide__sub">{{ block.settings.subtext }}</p>
            <div class="vamas-slide__btns">
              <a href="{{ block.settings.btn1_url }}" class="btn-primary">{{ block.settings.btn1_text }}</a>
              <a href="{{ block.settings.btn2_url }}" class="btn-outline">{{ block.settings.btn2_text }}</a>
            </div>
          </div>
          <div class="vamas-slider__image">
            {% if block.settings.slide_image != blank %}
              <img src="{{ block.settings.slide_image | img_url: '640x840', crop: 'center' }}"
                   alt="{{ block.settings.slide_image.alt | escape | default: block.settings.line1 }}"
                   loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                   width="640" height="840">
            {% else %}
              {{ 'model-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

  </div>

  {% assign slide_count = 0 %}
  {% for block in section.blocks %}{% if block.type == 'slide' %}{% assign slide_count = slide_count | plus: 1 %}{% endif %}{% endfor %}

  {% if slide_count > 1 %}
    <button class="vamas-slider__arrow vamas-slider__arrow--prev" id="vamas-prev" aria-label="Previous slide">&#8592;</button>
    <button class="vamas-slider__arrow vamas-slider__arrow--next" id="vamas-next" aria-label="Next slide">&#8594;</button>
    <div class="vamas-slider__dots" id="vamas-dots">
      {% assign idx = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'slide' %}
          <button class="vamas-slider__dot {% if idx == 0 %}active{% endif %}"
                  data-idx="{{ idx }}" aria-label="Slide {{ idx | plus: 1 }}"></button>
          {% assign idx = idx | plus: 1 %}
        {% endif %}
      {% endfor %}
    </div>
  {% endif %}
</div>

<script>
(function(){
  var track = document.getElementById('vamas-track');
  var dots  = document.querySelectorAll('#vamas-dots .vamas-slider__dot');
  var cur   = 0;
  var total = dots.length;
  var timer;
  if(!track || total < 2) return;

  function goTo(i){
    cur = (i + total) % total;
    track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    dots.forEach(function(d,j){ d.classList.toggle('active', j === cur); });
  }

  function reset(){ clearInterval(timer); timer = setInterval(function(){ goTo(cur+1); }, 5000); }

  var prev = document.getElementById('vamas-prev');
  var next = document.getElementById('vamas-next');
  if(prev) prev.addEventListener('click', function(){ goTo(cur-1); reset(); });
  if(next) next.addEventListener('click', function(){ goTo(cur+1); reset(); });
  dots.forEach(function(d){ d.addEventListener('click', function(){ goTo(+this.dataset.idx); reset(); }); });
  reset();
})();
</script>

{% comment %} ── Trust Bar ────────────────────────── {% endcomment %}
<div class="vamas-trust">
  <div class="vamas-trust__item">
    <div class="vamas-trust__icon">
      <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    </div>
    <div><div class="vamas-trust__title">100% Authentic</div><div class="vamas-trust__sub">Genuine handcrafted fabric</div></div>
  </div>
  <div class="vamas-trust__item">
    <div class="vamas-trust__icon">
      <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
    </div>
    <div><div class="vamas-trust__title">Fast Delivery</div><div class="vamas-trust__sub">3–5 business days</div></div>
  </div>
  <div class="vamas-trust__item">
    <div class="vamas-trust__icon">
      <svg viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.5"/></svg>
    </div>
    <div><div class="vamas-trust__title">Easy Returns</div><div class="vamas-trust__sub">7-day hassle-free</div></div>
  </div>
  <div class="vamas-trust__item">
    <div class="vamas-trust__icon">
      <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
    </div>
    <div><div class="vamas-trust__title">Secure Payment</div><div class="vamas-trust__sub">UPI · Card · Net Banking · COD</div></div>
  </div>
</div>

{% comment %} ── Categories ───────────────────────── {% endcomment %}
{% assign cat_blocks = section.blocks | where: 'type', 'category' %}
{% if cat_blocks.size > 0 and section.settings.show_categories %}
<section class="vamas-section">
  <div class="vamas-section__header">
    <div>
      <h2 class="vamas-section__title">Shop by <span>Occasion</span></h2>
      <p class="vamas-section__subtitle">Find the perfect blouse for every moment</p>
    </div>
    <a href="{{ section.settings.cat_view_all | default: '/collections/all' }}" class="vamas-view-all">VIEW ALL</a>
  </div>
  <div class="vamas-cat-grid">
    {% for block in section.blocks %}
      {% if block.type == 'category' %}
        <a href="{{ block.settings.cat_url | default: '/collections/all' }}" class="vamas-cat-card">
          {% if block.settings.cat_image != blank %}
            <img src="{{ block.settings.cat_image | img_url: '400x533', crop: 'center' }}"
                 alt="{{ block.settings.cat_name }}" loading="lazy" width="400" height="533">
          {% else %}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
          <div class="vamas-cat-card__overlay">
            <div>
              <div class="vamas-cat-card__label">{{ block.settings.cat_name }}</div>
              <div class="vamas-cat-card__count">{{ block.settings.cat_count }} styles</div>
            </div>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% comment %} ── New Arrivals ─────────────────────── {% endcomment %}
{% if section.settings.show_new_arrivals %}
<section class="vamas-section vamas-section--alt">
  <div class="vamas-section__header">
    <div>
      <h2 class="vamas-section__title">New <span>Arrivals</span></h2>
      <p class="vamas-section__subtitle">Fresh styles added every week</p>
    </div>
    <a href="{{ collections[section.settings.new_arrivals_collection].url | default: '/collections/all' }}" class="vamas-view-all">VIEW ALL</a>
  </div>
  <div class="vamas-prod-grid">
    {% assign na_col = collections[section.settings.new_arrivals_collection] %}
    {% for product in na_col.products limit: 6 %}
      {% render 'vamas-product-card', product: product %}
    {% else %}
      {% for i in (1..6) %}{% render 'vamas-product-card-placeholder', index: i %}{% endfor %}
    {% endfor %}
  </div>
</section>
{% endif %}

{% comment %} ── Brand Story ──────────────────────── {% endcomment %}
{% if section.settings.show_brand %}
<section class="vamas-brand">
  <div class="vamas-brand__text">
    <p class="vamas-brand__eyebrow">{{ section.settings.brand_eyebrow | default: 'OUR STORY' }}</p>
    <h2 class="vamas-brand__heading">{{ section.settings.brand_heading }}</h2>
    <p class="vamas-brand__text-body">{{ section.settings.brand_text }}</p>
    <div class="vamas-brand__stats">
      {% for block in section.blocks %}
        {% if block.type == 'stat' %}
          <div>
            <div class="vamas-brand__stat-num">{{ block.settings.stat_num }}</div>
            <div class="vamas-brand__stat-lbl">{{ block.settings.stat_lbl }}</div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
    <a href="{{ section.settings.brand_btn_url | default: '/pages/about' }}" class="btn-outline">
      {{ section.settings.brand_btn_text | default: 'EXPLORE OUR STORY' }}
    </a>
  </div>
  <div class="vamas-brand__image">
    {% if section.settings.brand_image != blank %}
      <img src="{{ section.settings.brand_image | img_url: '500x640', crop: 'center' }}"
           alt="Vamas brand story" loading="lazy" width="500" height="640">
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </div>
</section>
{% endif %}

{% comment %} ── Best Sellers ─────────────────────── {% endcomment %}
{% if section.settings.show_bestsellers %}
<section class="vamas-section">
  <div class="vamas-section__header">
    <div>
      <h2 class="vamas-section__title">Best <span>Sellers</span></h2>
      <p class="vamas-section__subtitle">Most loved by our customers</p>
    </div>
    <a href="{{ collections[section.settings.bestsellers_collection].url | default: '/collections/all' }}" class="vamas-view-all">VIEW ALL</a>
  </div>
  <div class="vamas-prod-grid">
    {% assign bs_col = collections[section.settings.bestsellers_collection] %}
    {% for product in bs_col.products limit: 6 %}
      {% render 'vamas-product-card', product: product %}
    {% else %}
      {% for i in (1..6) %}{% render 'vamas-product-card-placeholder', index: i %}{% endfor %}
    {% endfor %}
  </div>
</section>
{% endif %}

