{{ 'vamas-theme.css' | asset_url | stylesheet_tag }}

<footer class="vamas-footer">
  <div class="vamas-footer__grid">

    <div>
      <div class="vamas-footer__logo">
        <div class="vamas-footer__logo-mark">
          <img src="{{ 'vamas-logo.avif' | asset_url }}" alt="Vamas Logo" width="34" height="34">
        </div>
        <span class="vamas-footer__brand">{{ section.settings.brand_name }}</span>
      </div>
      <p class="vamas-footer__desc">{{ section.settings.brand_desc }}</p>
      <div class="vamas-footer__socials">
        {% if section.settings.instagram != blank %}
          <a href="{{ section.settings.instagram }}" class="vamas-footer__social" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
        {% endif %}
        {% if section.settings.facebook != blank %}
          <a href="{{ section.settings.facebook }}" class="vamas-footer__social" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        {% endif %}
        {% if section.settings.whatsapp != blank %}
          <a href="https://wa.me/{{ section.settings.whatsapp }}" class="vamas-footer__social" aria-label="WhatsApp" target="_blank" rel="noopener">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    <div>
      <div class="vamas-footer__col-title">QUICK LINKS</div>
      <div class="vamas-footer__links">
        <a href="/collections/new-arrivals">New Arrivals</a>
        <a href="/collections/all">All Collections</a>
        <a href="/collections/best-sellers">Best Sellers</a>
        <a href="/pages/about">About Us</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </div>

    <div>
      <div class="vamas-footer__col-title">CUSTOMER CARE</div>
      <div class="vamas-footer__links">
        <a href="/pages/size-guide">Size Guide</a>
        <a href="/pages/track-order">Track Order</a>
        <a href="/policies/refund-policy">Returns & Exchange</a>
        <a href="/pages/faq">FAQ</a>
        <a href="/pages/shipping">Shipping Policy</a>
      </div>
    </div>

    <div>
      <div class="vamas-footer__col-title">CONTACT US</div>
      <div class="vamas-footer__links">
        {% if section.settings.contact_email != blank %}
          <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
        {% endif %}
        {% if section.settings.contact_phone != blank %}
          <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
        {% endif %}
        {% if section.settings.contact_hours != blank %}
          <span style="color:rgba(231,209,166,0.4);font-size:11px;">{{ section.settings.contact_hours }}</span>
        {% endif %}
      </div>
    </div>

  </div>

  <div class="vamas-footer__bottom">
    <div class="vamas-footer__copy">© {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. All rights reserved.</div>
    <div class="vamas-footer__payments">
      <span class="vamas-footer__payment-icon" style="font-size:11px;color:rgba(231,209,166,0.5);">UPI &nbsp;|&nbsp; Cards &nbsp;|&nbsp; Net Banking &nbsp;|&nbsp; COD</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Vamas Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand Name", "default": "VAMAS" },
    { "type": "textarea", "id": "brand_desc", "label": "Brand Description", "default": "Premium handcrafted blouses celebrating Indian artistry and elegance. Every piece tells a story." },
    { "type": "header", "content": "Social Links" },
    { "type": "text", "id": "instagram", "label": "Instagram URL" },
    { "type": "text", "id": "facebook", "label": "Facebook URL" },
    { "type": "text", "id": "whatsapp", "label": "WhatsApp Number (with country code)", "placeholder": "919876543210" },
    { "type": "header", "content": "Contact" },
    { "type": "text", "id": "contact_email", "label": "Email" },
    { "type": "text", "id": "contact_phone", "label": "Phone" },
    { "type": "text", "id": "contact_hours", "label": "Support Hours", "default": "Mon–Sat: 10am – 6pm" }
  ],
  "presets": [{ "name": "Vamas Footer" }]
}
{% endschema %}
